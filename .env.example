# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings -> API). The anon key is safe to expose in the client:
# all data access is controlled by Row Level Security policies.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Web Push (public key only — the PRIVATE key lives in Supabase secrets, never here)
# Generate the pair once with:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Optional: Sentry error monitoring (leave empty to disable)
VITE_SENTRY_DSN=

# Google Maps (public, but MUST be domain-restricted in Google Cloud Console —
# see README "Google Maps setup"). Needs: Maps JavaScript API + Places API.
VITE_GOOGLE_MAPS_API_KEY=
